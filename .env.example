# Auth (required in production)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Shared invite code for sign-up (required in production)
# Generate: openssl rand -hex 32  (64 hex chars, same format as SHA-256)
REGISTRATION_CODE=

# Production HTTPS (docker-compose.prod.yml)
DOMAIN=todos.example.com

# Optional: Ollama emoji model
OLLAMA_MODEL=llama3.2:1b
